    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:tipcalculator11"
    Title="tipcalculator11">


    <TabBar>

    <ShellContent
        Title="Calculadora de Gorjetas"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Sobre o Projeto"
        ContentTemplate="{DataTemplate local:SobrePage1}"
        Route="SobrePage1" />
    
    </TabBar>

</Shell>
