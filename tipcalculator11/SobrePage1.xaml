<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="tipcalculator11.SobrePage1"
             Title="SobrePage1">
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Image
        Source="foto2.png"
        WidthRequest="150"
        HeightRequest="150"
        />
        <Label
        HorizontalOptions="Center"
        Text="Feito por : Danner"
        />
        <Button
        x:Name="GitHubButton"
        Text="Ir para o Repositorio"
        Clicked="GitHubButton_Clicked"
            />
        
    </VerticalStackLayout>
</ContentPage>